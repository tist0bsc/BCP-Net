{
  "num_classes": 2,
  "input_channels": 1,
  "device": "cuda:0",
  "batch_size": 32,
  "num_epoch": 100,
  "num_workers": 0,
  "lr": 0.0001,
  "weight_decay": 0.0001,
  "train_list": "data/HISEA/train.txt",
  "val_list": "data/HISEA/val.txt",
  "test_list": "data/HISEA/test.txt",
  "dataset": {
    "name": "HISEA",
    "image_mode": "auto",
    "label_mode": "auto",
    "paired_input_mode": "stack",
    "augmentation": {
      "enable": true,
      "hflip_prob": 0.5,
      "vflip_prob": 0.5,
      "rot90_prob": 0.25
    }
  },
  "optimizer": {
    "type": "AdamW",
    "beta1": 0.9,
    "beta2": 0.999
  },
  "scheduler": {
    "type": "linear"
  },
  "loss": {
    "tversky_weight": 0.5,
    "tversky_alpha": 0.3,
    "tversky_beta": 0.7,
    "edge_weight": 0.2,
    "edge_pos_weight": 4.0,
    "boundary_width": 3
  },
  "save_dir": "saved/HISEA/BCP-Net",
  "best_metric": "mIoU",
  "test_metric": "mIoU",
  "test_during_train": true,
  "test_interval": 5
}
